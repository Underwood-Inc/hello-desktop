{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hello Desktop",
  "version": "0.1.0",
  "identifier": "com.example.hello-desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:electron",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Hello Desktop",
        "width": 960,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false,
        "backgroundColor": "#1a1b26"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default", "second-window"],
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Example",
    "category": "DeveloperTool",
    "shortDescription": "Minimal Vite + Electron + Tauri desktop starter.",
    "longDescription": "Hello-world shell aligned with create-tauri-app vanilla-ts; same dist for Electron and Tauri.",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": false
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}
