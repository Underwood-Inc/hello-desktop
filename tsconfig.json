{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vite/client"],
    "paths": {
      "$atoms/*": ["./src/atoms/*"],
      "$molecules/*": ["./src/molecules/*"],
      "$sockets/*": ["./src/sockets/*"],
      "$plugs/*": ["./src/plugs/*"],
      "$frames/*": ["./src/frames/*"],
      "$recipes/*": ["./src/recipes/*"],
      "$views/*": ["./src/views/*"],
      "$apps/*": ["./src/apps/*"]
    }
  },
  "include": ["src/**/*.ts", "vite.config.ts"]
}
